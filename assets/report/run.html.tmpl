<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
{{- if .InProgress}}
<meta http-equiv="refresh" content="5">
{{- end}}
<title>stfw run {{.RunID}}</title>
<style>
:root { color-scheme: light; }
* { box-sizing: border-box; }
body { margin: 0; padding: 24px; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans", Meiryo, sans-serif; background: #f5f6f8; color: #24292f; }
a { color: #0969da; text-decoration: none; }
a:hover { text-decoration: underline; }
h1 { margin: 0 0 4px; font-size: 20px; }
.meta { color: #57606a; font-size: 13px; margin-bottom: 16px; }
.summary { display: flex; flex-wrap: wrap; gap: 16px; background: #fff; border: 1px solid #d0d7de; border-radius: 6px; padding: 12px 16px; margin-bottom: 16px; font-size: 13px; }
.summary dt { color: #57606a; margin-bottom: 2px; }
.summary dd { margin: 0; font-weight: 600; }
.tablewrap { overflow-x: auto; background: #fff; border: 1px solid #d0d7de; border-radius: 6px; }
table { border-collapse: collapse; width: 100%; font-size: 13px; }
th, td { padding: 6px 12px; text-align: left; border-top: 1px solid #d8dee4; white-space: nowrap; }
thead th { border-top: none; background: #f6f8fa; color: #57606a; font-weight: 600; }
.name { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
.type { color: #57606a; }
.step .name { color: #57606a; }
.status { display: inline-block; padding: 1px 8px; border-radius: 10px; font-size: 12px; font-weight: 600; }
.st-Success { background: #dafbe1; color: #116329; }
.st-Error { background: #ffebe9; color: #a40e26; }
.st-Started { background: #ddf4ff; color: #0550ae; }
.st-Pending { background: #eaeef2; color: #57606a; }
.st-Blocked { background: #fff1e5; color: #953800; }
.st-Unknown { background: #eaeef2; color: #57606a; }
</style>
</head>
<body>
<h1>run {{.RunID}}</h1>
<p class="meta"><a href="../index.html">&laquo; run list</a> / generated at {{.GeneratedAt}}{{if .InProgress}} (auto refresh: 5s){{end}}</p>
<dl class="summary">
  <div><dt>status</dt><dd><span class="status st-{{.Status}}">{{.Status}}</span></dd></div>
  <div><dt>mode</dt><dd>{{.Mode}}</dd></div>
  <div><dt>params</dt><dd>{{.Params}}</dd></div>
  <div><dt>start</dt><dd>{{.StartTime}}</dd></div>
  <div><dt>end</dt><dd>{{.EndTime}}</dd></div>
  <div><dt>processing time</dt><dd>{{.ProcessingTime}}</dd></div>
</dl>
<div class="tablewrap">
<table>
  <thead>
    <tr><th>node</th><th>type</th><th>status</th><th>start</th><th>end</th><th>processing time</th></tr>
  </thead>
  <tbody>
    {{- range .Nodes}}
    <tr>
      <td class="name" style="padding-left: {{.IndentPx}}px">{{.Name}}</td>
      <td class="type">{{.Type}}</td>
      <td><span class="status st-{{.Status}}">{{.Status}}</span></td>
      <td>{{.StartTime}}</td>
      <td>{{.EndTime}}</td>
      <td>{{.ProcessingTime}}</td>
    </tr>
    {{- $indent := .StepIndentPx}}
    {{- range .Steps}}
    <tr class="step">
      <td class="name" style="padding-left: {{$indent}}px">- {{.Name}}</td>
      <td class="type">step</td>
      <td><span class="status st-{{.Status}}">{{.Status}}</span></td>
      <td>{{.StartTime}}</td>
      <td>{{.EndTime}}</td>
      <td>{{.ProcessingTime}}</td>
    </tr>
    {{- end}}
    {{- end}}
  </tbody>
</table>
</div>
</body>
</html>
