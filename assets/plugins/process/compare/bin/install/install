#!/bin/bash
# compare のプロビジョニング: compare-files バイナリ (実行ホストの os_arch 版) を
# ダウンロードして永続キャッシュ (${stfw_plugin_cache_dir}/compare-files/{os_arch}/compare_files)
# に配置する。compare-files はローカルで expect/actual を比較するため、実行ホストの
# arch 1 種のみ取得する (収集系プラグインのように送り分けはしない)。
#
# プロビジョニングモデルは collectLog (logfilter) と同一の「初回 install 優先」。
# 既にキャッシュ済みなら再ダウンロードしない。compare_files_version を変更したときは
# ${stfw_plugin_cache_dir}/compare-files/ を削除してから再 install すること。
#
# 取得・展開・配置に失敗した場合は非 0 (exit 6) を返す。
set -uo pipefail

for cmd in curl tar uname; do
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "compare install: ${cmd} is required" >&2
    exit 6
  fi
done

os=""
case "$(uname -s)" in
  Linux) os=linux ;;
  Darwin) os=darwin ;;
  *) echo "compare install: unsupported OS: $(uname -s)" >&2; exit 6 ;;
esac
arch=""
case "$(uname -m)" in
  x86_64 | amd64) arch=amd64 ;;
  aarch64 | arm64) arch=arm64 ;;
  *) echo "compare install: unsupported arch: $(uname -m)" >&2; exit 6 ;;
esac
os_arch="${os}_${arch}"

version="${stfw_process_compare_compare_files_version:-v2.2.0}"
# リリース資産名はバージョンに先頭 v を含まない (compare-files_2.2.0_linux_amd64.tar.gz)。
version_num="${version#v}"
# ダウンロード元は既定で GitHub Releases。テスト等で差し替え可能にする。
base="${stfw_compare_files_download_base:-https://github.com/scenario-test-framework/compare-files/releases/download/${version}}"
dest="${stfw_plugin_cache_dir}/compare-files/${os_arch}"

if [ -x "${dest}/compare_files" ]; then
  exit 0
fi

mkdir -p "${dest}"
tarball="compare-files_${version_num}_${os_arch}.tar.gz"
tmp="$(mktemp -d)"

if ! curl -fsSL "${base}/${tarball}" -o "${tmp}/${tarball}"; then
  echo "compare install: download failed: ${base}/${tarball}" >&2
  rm -rf "${tmp}"
  exit 6
fi
if ! tar xzf "${tmp}/${tarball}" -C "${tmp}"; then
  echo "compare install: extract failed: ${tarball}" >&2
  rm -rf "${tmp}"
  exit 6
fi
bin="$(find "${tmp}" -type f -name compare_files | head -1)"
if [ -z "${bin}" ]; then
  echo "compare install: compare_files binary not found in ${tarball}" >&2
  rm -rf "${tmp}"
  exit 6
fi
if ! cp "${bin}" "${dest}/compare_files" || ! chmod 755 "${dest}/compare_files"; then
  echo "compare install: failed to place compare_files for ${os_arch}" >&2
  rm -rf "${tmp}"
  exit 6
fi
rm -rf "${tmp}"
exit 0
