#!/bin/bash
# clearPostgres: PostgreSQL のテーブルの全行を DELETE する (Arrange の初期化)。
#
# 設定 (config.yml の stfw.process.clearPostgres): host_group / port / database / user / tables
# 処理: 全テーブルの DELETE FROM を単一 --command で発行する (psql -c の複数文は
# 単一トランザクション処理のため all-or-nothing)。FK 制約は無効化しないので、
# tables は FK の子 → 親順に列挙する。参照行が残る親の削除は DBMS のエラーで失敗する。
#
# 接続情報 (ホスト/パスワード) は inventory / secret から解決し config に直書きしない。
set -uo pipefail

host_group="${stfw_process_clearPostgres_host_group:-}"
port="${stfw_process_clearPostgres_port:-5432}"
database="${stfw_process_clearPostgres_database:-}"
user="${stfw_process_clearPostgres_user:-}"

if [ -z "${host_group}" ] || [ -z "${database}" ] || [ -z "${user}" ]; then
  echo "clearPostgres: host_group / database / user are required" >&2
  exit 6
fi

if ! hosts="$(stfw inventory list "${host_group}")"; then
  echo "clearPostgres: inventory list failed for group: ${host_group}" >&2
  exit 6
fi
# RDBMS は単一 DB サーバを対象とする。複数解決時は先頭ホストを使い警告する。
# shellcheck disable=SC2086
set -- ${hosts}
host="${1:-}"
if [ -z "${host}" ]; then
  echo "clearPostgres: no host resolved for group: ${host_group}" >&2
  exit 6
fi
if [ "$#" -gt 1 ]; then
  echo "clearPostgres: group ${host_group} resolves to multiple hosts; using ${host}" >&2
fi

if ! password="$(stfw secret show "${host}" "${user}")"; then
  echo "clearPostgres: secret not found: ${host}-${user}" >&2
  exit 6
fi

sql=""
i=0
while :; do
  t_var="stfw_process_clearPostgres_tables_${i}"
  table="${!t_var:-}"
  [ -z "${table}" ] && break
  i=$((i + 1))

  # 識別子はダブルクオート内のダブルクオートを二重化してエスケープする。
  t_esc="$(printf '%s' "${table}" | sed 's/"/""/g')"
  sql="${sql:+${sql}; }DELETE FROM \"${t_esc}\""
done

# tables 0 件は no-op (設定漏れ検知は validate / README の注意書きに委ねる)
if [ -z "${sql}" ]; then
  exit 0
fi

if ! PGPASSWORD="${password}" psql --host="${host}" --port="${port}" \
    --username="${user}" --dbname="${database}" \
    --set=ON_ERROR_STOP=1 --no-psqlrc --quiet \
    --command="${sql}"; then
  echo "clearPostgres: delete failed: ${database}" >&2
  exit 6
fi

exit 0
