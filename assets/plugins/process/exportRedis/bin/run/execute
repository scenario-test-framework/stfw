#!/bin/bash
# exportRedis: Redis のキーをヘッダー付き CSV (key,type,ttl,value) でエクスポートする。
#
# 設定 (config.yml の stfw.process.exportRedis):
#   host_group / port / db / user / key_patterns[].{name,match}
#
# 処理: match ごとに SCAN でキー列挙 → 各キーの type/ttl/値 (redis-cli -2 --json) を
#   内部ヘルパ `stfw plugin redis-encode-row` で正規化 + CSV 化する。
#   value は string=生値、list/set/hash/zset=キー順ソートの正規化 JSON。
# 出力: ${stfw_process_dir}/evidence/{host}/{name}.csv (エビデンス規約)
#
# 値は UTF-8 テキストを対象 (バイナリ値は対象外)。SCAN 出力は改行区切りのため
# 改行を含むキーは非対応。接続情報は inventory/secret から解決し config に直書きしない。
set -uo pipefail

evidence_root="${stfw_process_dir}/evidence"
host_group="${stfw_process_exportRedis_host_group:-}"
port="${stfw_process_exportRedis_port:-6379}"
db="${stfw_process_exportRedis_db:-0}"
user="${stfw_process_exportRedis_user:-}"
rc=0

if [ -z "${host_group}" ]; then
  echo "exportRedis: host_group is required" >&2
  exit 6
fi

if ! hosts="$(stfw inventory list "${host_group}")"; then
  echo "exportRedis: inventory list failed for group: ${host_group}" >&2
  exit 6
fi
# RDBMS/KVS は単一サーバを対象とする。複数解決時は先頭ホストを使い警告する。
# shellcheck disable=SC2086
set -- ${hosts}
host="${1:-}"
if [ -z "${host}" ]; then
  echo "exportRedis: no host resolved for group: ${host_group}" >&2
  exit 6
fi
if [ "$#" -gt 1 ]; then
  echo "exportRedis: group ${host_group} resolves to multiple hosts; using ${host}" >&2
fi

if ! password="$(stfw secret show "${host}" "${user}")"; then
  echo "exportRedis: secret not found: ${host}-${user}" >&2
  exit 6
fi
export REDISCLI_AUTH="${password}"

redis_opts=(-h "${host}" -p "${port}" -n "${db}" --no-auth-warning)
[ -n "${user}" ] && redis_opts+=(--user "${user}")

destdir="${evidence_root}/${host}"
mkdir -p "${destdir}"

i=0
while :; do
  name_var="stfw_process_exportRedis_key_patterns_${i}_name"
  match_var="stfw_process_exportRedis_key_patterns_${i}_match"
  name="${!name_var:-}"
  match="${!match_var:-}"
  [ -z "${name}" ] && break
  i=$((i + 1))

  out="${destdir}/${name}.csv"
  tmp="${out}.tmp.$$"
  echo 'key,type,ttl,value' > "${tmp}"

  if ! keys="$(redis-cli "${redis_opts[@]}" --scan --pattern "${match}")"; then
    echo "exportRedis: scan failed for pattern: ${match}" >&2
    rm -f "${tmp}"
    rc=6
    continue
  fi

  # SCAN 結果を 1 キーずつ処理する (here-string のため while はサブシェルにならず
  # rc がループ外へ伝播する)。ループ内の redis-cli は stdin を読まない。
  while IFS= read -r key; do
    [ -z "${key}" ] && continue
    type="$(redis-cli "${redis_opts[@]}" TYPE "${key}")"
    [ "${type}" = "none" ] && continue
    ttl="$(redis-cli "${redis_opts[@]}" TTL "${key}")"

    case "${type}" in
      string) val="$(redis-cli "${redis_opts[@]}" -2 --json GET "${key}")" ;;
      list) val="$(redis-cli "${redis_opts[@]}" -2 --json LRANGE "${key}" 0 -1)" ;;
      set) val="$(redis-cli "${redis_opts[@]}" -2 --json SMEMBERS "${key}")" ;;
      hash) val="$(redis-cli "${redis_opts[@]}" -2 --json HGETALL "${key}")" ;;
      zset) val="$(redis-cli "${redis_opts[@]}" -2 --json ZRANGE "${key}" 0 -1 WITHSCORES)" ;;
      *)
        echo "exportRedis: unsupported type ${type} for key ${key}" >&2
        rc=6
        continue
        ;;
    esac

    if ! printf '%s' "${val}" | stfw plugin redis-encode-row \
        --key "${key}" --type "${type}" --ttl "${ttl}" >> "${tmp}"; then
      echo "exportRedis: encode failed for key ${key}" >&2
      rc=6
      continue
    fi
  done <<< "${keys}"

  mv "${tmp}" "${out}"
done

exit ${rc}
