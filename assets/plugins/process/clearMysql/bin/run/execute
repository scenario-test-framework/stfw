#!/bin/bash
# clearMysql: MySQL のテーブルを truncate する (Arrange の初期化)。
#
# 設定 (config.yml の stfw.process.clearMysql): host_group / port / database / user / tables
# 処理: 各テーブルを TRUNCATE TABLE する。
#
# 接続情報 (ホスト/パスワード) は inventory / secret から解決し config に直書きしない。
set -uo pipefail

host_group="${stfw_process_clearMysql_host_group:-}"
port="${stfw_process_clearMysql_port:-3306}"
database="${stfw_process_clearMysql_database:-}"
user="${stfw_process_clearMysql_user:-}"
rc=0

if [ -z "${host_group}" ] || [ -z "${database}" ] || [ -z "${user}" ]; then
  echo "clearMysql: host_group / database / user are required" >&2
  exit 6
fi

if ! hosts="$(stfw inventory list "${host_group}")"; then
  echo "clearMysql: inventory list failed for group: ${host_group}" >&2
  exit 6
fi
# RDBMS は単一 DB サーバを対象とする。複数解決時は先頭ホストを使い警告する。
# shellcheck disable=SC2086
set -- ${hosts}
host="${1:-}"
if [ -z "${host}" ]; then
  echo "clearMysql: no host resolved for group: ${host_group}" >&2
  exit 6
fi
if [ "$#" -gt 1 ]; then
  echo "clearMysql: group ${host_group} resolves to multiple hosts; using ${host}" >&2
fi

if ! password="$(stfw secret show "${host}" "${user}")"; then
  echo "clearMysql: secret not found: ${host}-${user}" >&2
  exit 6
fi

i=0
while :; do
  t_var="stfw_process_clearMysql_tables_${i}"
  table="${!t_var:-}"
  [ -z "${table}" ] && break
  i=$((i + 1))

  # 識別子はバッククオート内のバッククオートを二重化してエスケープする。
  t_esc="$(printf '%s' "${table}" | sed 's/`/``/g')"
  if ! MYSQL_PWD="${password}" mysql --host="${host}" --port="${port}" \
      --user="${user}" --database="${database}" \
      --execute="TRUNCATE TABLE \`${t_esc}\`"; then
    echo "clearMysql: truncate failed: ${database}.${table}" >&2
    rc=6
  fi
done

exit ${rc}
