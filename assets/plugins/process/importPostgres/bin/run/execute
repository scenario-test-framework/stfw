#!/bin/bash
# importPostgres: ヘッダー付き CSV を PostgreSQL のテーブルへインポートする (Arrange)。
#
# 設定 (config.yml の stfw.process.importPostgres): host_group / port / database / user / tables
# 入力: ${stfw_process_dir}/data/{database}/{table}.csv (exportPostgres 出力形式)
# 処理: psql の \copy ... FROM (クライアント側ファイル入力) で CSV を投入する。
#
# 接続情報 (ホスト/パスワード) は inventory / secret から解決し config に直書きしない。
set -uo pipefail

data_root="${stfw_process_dir}/data"
host_group="${stfw_process_importPostgres_host_group:-}"
port="${stfw_process_importPostgres_port:-5432}"
database="${stfw_process_importPostgres_database:-}"
user="${stfw_process_importPostgres_user:-}"
rc=0

if [ -z "${host_group}" ] || [ -z "${database}" ] || [ -z "${user}" ]; then
  echo "importPostgres: host_group / database / user are required" >&2
  exit 6
fi

if ! hosts="$(stfw inventory list "${host_group}")"; then
  echo "importPostgres: inventory list failed for group: ${host_group}" >&2
  exit 6
fi
# RDBMS は単一 DB サーバを対象とする。複数解決時は先頭ホストを使い警告する。
# shellcheck disable=SC2086
set -- ${hosts}
host="${1:-}"
if [ -z "${host}" ]; then
  echo "importPostgres: no host resolved for group: ${host_group}" >&2
  exit 6
fi
if [ "$#" -gt 1 ]; then
  echo "importPostgres: group ${host_group} resolves to multiple hosts; using ${host}" >&2
fi

if ! password="$(stfw secret show "${host}" "${user}")"; then
  echo "importPostgres: secret not found: ${host}-${user}" >&2
  exit 6
fi

i=0
while :; do
  t_var="stfw_process_importPostgres_tables_${i}"
  table="${!t_var:-}"
  [ -z "${table}" ] && break
  i=$((i + 1))

  src="${data_root}/${database}/${table}.csv"
  if [ ! -f "${src}" ]; then
    echo "importPostgres: source csv not found: ${src}" >&2
    rc=6
    continue
  fi

  # 識別子はダブルクオート内のダブルクオートを二重化してエスケープする。
  # 入力ファイルパスは SQL に載せず、COPY ... FROM STDIN をシェルリダイレクトで
  # 与える (psql メタコマンド \copy のパス解釈=バックスラッシュ等を回避)。
  t_esc="$(printf '%s' "${table}" | sed 's/"/""/g')"
  copy="COPY \"${t_esc}\" FROM STDIN WITH (FORMAT csv, HEADER true, NULL '\\N')"
  if ! PGPASSWORD="${password}" psql --host="${host}" --port="${port}" \
      --username="${user}" --dbname="${database}" \
      --set=ON_ERROR_STOP=1 --no-psqlrc --quiet --command="${copy}" < "${src}"; then
    echo "importPostgres: import failed: ${database}.${table}" >&2
    rc=6
  fi
done

exit ${rc}
