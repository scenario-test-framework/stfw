#!/bin/bash
# invokeWeb のプロビジョニング: k6 バイナリ (実行ホストの os_arch 版) をダウンロードして
# 永続キャッシュ (${stfw_plugin_cache_dir}/k6/{os_arch}/k6) に配置する。k6 はローカルで
# テストを実行するため、実行ホストの arch 1 種のみ取得する。
#
# ブラウザモード (invokeWeb) は実行時に Chromium を必要とする (stfw:full イメージに同梱)。
# 本 install は k6 バイナリのみを配置し、Chromium の導入はイメージ/実行環境の責務とする。
#
# プロビジョニングモデルは collectLog (logfilter) と同一の「初回 install 優先」。
# 既にキャッシュ済みなら再ダウンロードしない。k6_version を変更したときは
# ${stfw_plugin_cache_dir}/k6/ を削除してから再 install すること。
#
# k6 のリリース資産名は k6-{version}-{os}-{arch}.{tar.gz|zip} (linux=tar.gz / macos=zip、
# os=linux|macos、arch=amd64|arm64)。取得・展開・配置に失敗した場合は非 0 (exit 6) を返す。
set -uo pipefail

case "$(uname -s)" in
  Linux) k6_os=linux; ext=tar.gz ;;
  Darwin) k6_os=macos; ext=zip ;;
  *) echo "invokeWeb install: unsupported OS: $(uname -s)" >&2; exit 6 ;;
esac
case "$(uname -m)" in
  x86_64 | amd64) arch=amd64 ;;
  aarch64 | arm64) arch=arm64 ;;
  *) echo "invokeWeb install: unsupported arch: $(uname -m)" >&2; exit 6 ;;
esac
os_arch="${k6_os}_${arch}"

reqs="curl uname"
[ "${ext}" = "tar.gz" ] && reqs="${reqs} tar"
[ "${ext}" = "zip" ] && reqs="${reqs} unzip"
for cmd in ${reqs}; do
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "invokeWeb install: ${cmd} is required" >&2
    exit 6
  fi
done

version="${stfw_process_invokeWeb_k6_version:-v2.1.0}"
base="${stfw_k6_download_base:-https://github.com/grafana/k6/releases/download/${version}}"
dest="${stfw_plugin_cache_dir}/k6/${os_arch}"

if [ -x "${dest}/k6" ]; then
  exit 0
fi

mkdir -p "${dest}"
asset="k6-${version}-${k6_os}-${arch}.${ext}"
tmp="$(mktemp -d)"

if ! curl -fsSL "${base}/${asset}" -o "${tmp}/${asset}"; then
  echo "invokeWeb install: download failed: ${base}/${asset}" >&2
  rm -rf "${tmp}"
  exit 6
fi
if [ "${ext}" = "tar.gz" ]; then
  extracted=1
  tar xzf "${tmp}/${asset}" -C "${tmp}" || extracted=0
else
  extracted=1
  unzip -q "${tmp}/${asset}" -d "${tmp}" || extracted=0
fi
if [ "${extracted}" -eq 0 ]; then
  echo "invokeWeb install: extract failed: ${asset}" >&2
  rm -rf "${tmp}"
  exit 6
fi
bin="$(find "${tmp}" -type f -name k6 | head -1)"
if [ -z "${bin}" ]; then
  echo "invokeWeb install: k6 binary not found in ${asset}" >&2
  rm -rf "${tmp}"
  exit 6
fi
if ! cp "${bin}" "${dest}/k6" || ! chmod 755 "${dest}/k6"; then
  echo "invokeWeb install: failed to place k6 for ${os_arch}" >&2
  rm -rf "${tmp}"
  exit 6
fi
rm -rf "${tmp}"
exit 0
