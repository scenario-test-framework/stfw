# STEP: secret migrate (v0.2 の openssl S/MIME 形式 → age への一括変換)
# 旧形式 fixture は v0.2 bash_utils のコマンドラインを openssl で再現して生成する

[!exec:openssl] skip 'openssl not found'

exec stfw init

# 旧 RSA キーペア生成 (v0.2 の gen_encrypt_key と同じコマンドライン)
mkdir config/encrypt
exec openssl req -x509 -nodes -newkey rsa:2048 -keyout config/encrypt/decrypt_key -out config/encrypt/encrypt_key -subj /

# 旧形式 passwd ファイル生成 (v0.2 の `echo | openssl smime -encrypt -aes256 -binary -outform PEM` 相当。
# plain1.txt は echo と同じく末尾改行を含む)
mkdir config/passwd
exec openssl smime -encrypt -aes256 -binary -outform PEM -in plain1.txt -out config/passwd/127.0.0.1-some_user config/encrypt/encrypt_key

# age 鍵が無ければ keygen を促すエラー (exit 6)
execcode 6 stfw secret migrate
stderr 'stfw secret keygen'

# 旧形式のままの show はエラー (migrate を促す)
exec stfw secret keygen
! exec stfw secret show 127.0.0.1 some_user
stderr 'stfw secret migrate'

# migrate: 変換されたエントリ名が出力され、旧ファイルは .bak へ退避される
exec stfw secret migrate
stdout '^127.0.0.1-some_user$'
exists config/passwd/127.0.0.1-some_user
exists config/passwd/127.0.0.1-some_user.bak

# migrate 後は show で復号できる (末尾改行は除去されている)
exec stfw secret show 127.0.0.1 some_user
stdout '^migrated-password$'

# 再 migrate は変換対象なし (冪等)
exec stfw secret migrate
! stdout '127.0.0.1-some_user'

-- plain1.txt --
migrated-password
