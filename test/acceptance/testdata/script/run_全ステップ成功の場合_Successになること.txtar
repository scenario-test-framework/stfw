# STEP: run 正常系 (2 bizdate x 各 1 process が全 Success)
# ジャーナルのイベント列 (ts 以外) と階層フックの実行順をゴールデンで固定する

chmod 755 plugins/run/_common/setup/10_mark
chmod 755 plugins/run/_common/teardown/90_mark
chmod 755 plugins/scenario/_common/setup/10_mark
chmod 755 plugins/scenario/_common/teardown/90_mark
chmod 755 plugins/bizdate/_common/setup/10_mark
chmod 755 plugins/bizdate/_common/teardown/90_mark
chmod 755 plugins/process/_common/setup/10_mark
chmod 755 plugins/process/_common/teardown/90_mark

exec stfw run demo
stdout 'run_id: _'
stdout 'step1 day1'
stdout 'step2 day1'
stdout 'step1 day2'

# ジャーナルのイベント列 (ts 以外) がゴールデン一致
normjournal . journal_actual.jsonl
cmp journal_actual.jsonl journal_golden.jsonl

# 階層フックの実行順 + teardown への stfw_run_status / stfw_process_retcode 注入
cmp hooks.log hooks_golden.log

# status はジャーナルのリプレイで階層ツリーとステータスを表示する
exec stfw status
stdout 'run_id: _'
stdout 'run \[Success\]'
stdout '\n  demo \[Success\]'
stdout '\n    _10_99990101 \[Success\]'
stdout '\n      _10_pre_scripts \[Success\]'
stdout '\n        - 100_step1 \[Success\]'
stdout '\n        - 200_step2 \[Success\]'
stdout '\n    _20_99990102 \[Success\]'

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  timezone: "Asia/Tokyo"
-- scenario/demo/metadata.yml --
description:
-- scenario/demo/_10_99990101/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_pre_scripts/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_pre_scripts/config/config.yml --
stfw:
  process:
    scripts:
      some_key: value defined at scenario
-- scenario/demo/_10_99990101/_10_pre_scripts/scripts/100_step1 --
#!/bin/bash
echo "step1 day1"
exit 0
-- scenario/demo/_10_99990101/_10_pre_scripts/scripts/200_step2 --
#!/bin/bash
echo "step2 day1"
exit 0
-- scenario/demo/_20_99990102/metadata.yml --
description:
-- scenario/demo/_20_99990102/_10_pre_scripts/metadata.yml --
description:
-- scenario/demo/_20_99990102/_10_pre_scripts/config/config.yml --
stfw:
  process:
    scripts:
      some_key: value defined at scenario
-- scenario/demo/_20_99990102/_10_pre_scripts/scripts/100_step1 --
#!/bin/bash
echo "step1 day2"
exit 0
-- plugins/run/_common/setup/10_mark --
#!/bin/bash
echo "run setup" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/run/_common/teardown/90_mark --
#!/bin/bash
echo "run teardown ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/scenario/_common/setup/10_mark --
#!/bin/bash
echo "scenario setup ${stfw_scenario_name}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/scenario/_common/teardown/90_mark --
#!/bin/bash
echo "scenario teardown ${stfw_scenario_name} ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/bizdate/_common/setup/10_mark --
#!/bin/bash
echo "bizdate setup ${stfw_bizdate_dirname}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/bizdate/_common/teardown/90_mark --
#!/bin/bash
echo "bizdate teardown ${stfw_bizdate_dirname} ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/process/_common/setup/10_mark --
#!/bin/bash
echo "process setup ${stfw_process_dirname}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/process/_common/teardown/90_mark --
#!/bin/bash
echo "process teardown ${stfw_process_dirname} ${stfw_run_status} ${stfw_process_retcode}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- hooks_golden.log --
run setup
scenario setup demo
bizdate setup _10_99990101
process setup _10_pre_scripts
process teardown _10_pre_scripts Success 0
bizdate teardown _10_99990101 Success
bizdate setup _20_99990102
process setup _10_pre_scripts
process teardown _10_pre_scripts Success 0
bizdate teardown _20_99990102 Success
scenario teardown demo Success
run teardown Success
