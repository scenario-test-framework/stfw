# STEP: run Warn 系 (2 番目のステップが exit 3 -> Warn として記録し、
# 後続ステップ / process / bizdate は実行される。REQ-023)
# 集約は Error > Warn > Success: Warn を含む process / bizdate / scenario / run が Warn になり、
# run の終了コードは 3 (Warn あり・Error なし)。

chmod 755 plugins/run/_common/setup/10_mark
chmod 755 plugins/run/_common/teardown/90_mark
chmod 755 plugins/scenario/_common/setup/10_mark
chmod 755 plugins/scenario/_common/teardown/90_mark
chmod 755 plugins/bizdate/_common/setup/10_mark
chmod 755 plugins/bizdate/_common/teardown/90_mark
chmod 755 plugins/process/_common/setup/10_mark
chmod 755 plugins/process/_common/teardown/90_mark

execcode 3 stfw run demo
stderr 'finished with status Warn'

# Warn 後の後続ステップ・後続 process・後続 bizdate は実行される
exists executed_300_after.txt
exists executed_20_post.txt
exists executed_day2.txt

# ジャーナルのイベント列 (ts 以外) がゴールデン一致
# (Warn ステップの記録と全階層の Warn 集約を固定する)
normjournal . journal_actual.jsonl
cmp journal_actual.jsonl journal_golden.jsonl

# teardown フックには stfw_run_status=Warn / stfw_process_retcode=3 が渡る
cmp hooks.log hooks_golden.log

# status は Warn の階層とステップを表示する (パイプ出力のため色なし)
exec stfw status
stdout 'run \[Warn\]'
stdout '\n  demo \[Warn\]'
stdout '\n    _10_99990101 \[Warn\]'
stdout '\n      _10_pre_scripts \[Warn\]'
stdout '\n        - 200_warn \[Warn\]'
stdout '\n        - 300_after \[Success\]'
stdout '\n      _20_post_scripts \[Success\]'
stdout '\n    _20_99990102 \[Success\]'

# HTML レポート: Warn が st-Warn (黄) バッジで表示される (SPEC-024-02)
latestrun . WARN_RUN_ID
exec stfw report
grep 'st-Warn' .stfw/reports/runs/${WARN_RUN_ID}.html
grep 'st-Warn' .stfw/reports/index.html

# Warn なしジャーナル (旧バージョン相当) と Warn ありジャーナルの混在でも
# status / report が壊れない (SPEC-023-04)
exec stfw run demo2
exec stfw status
stdout 'run \[Success\]'
exec stfw status ${WARN_RUN_ID}
stdout 'run \[Warn\]'
exec stfw report
grep 'st-Warn' .stfw/reports/index.html
grep 'st-Success' .stfw/reports/index.html

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  timezone: "Asia/Tokyo"
-- scenario/demo/metadata.yml --
description:
-- scenario/demo/_10_99990101/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_pre_scripts/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_pre_scripts/config/config.yml --
stfw:
  process:
    scripts:
      some_key: value defined at scenario
-- scenario/demo/_10_99990101/_10_pre_scripts/scripts/100_ok --
#!/bin/bash
echo "100_ok"
exit 0
-- scenario/demo/_10_99990101/_10_pre_scripts/scripts/200_warn --
#!/bin/bash
echo "200_warn"
exit 3
-- scenario/demo/_10_99990101/_10_pre_scripts/scripts/300_after --
#!/bin/bash
touch "${STFW_PROJ_DIR}/executed_300_after.txt"
exit 0
-- scenario/demo/_10_99990101/_20_post_scripts/metadata.yml --
description:
-- scenario/demo/_10_99990101/_20_post_scripts/config/config.yml --
stfw:
  process:
    scripts:
      some_key: value defined at scenario
-- scenario/demo/_10_99990101/_20_post_scripts/scripts/100_marker --
#!/bin/bash
touch "${STFW_PROJ_DIR}/executed_20_post.txt"
exit 0
-- scenario/demo/_20_99990102/metadata.yml --
description:
-- scenario/demo/_20_99990102/_10_pre_scripts/metadata.yml --
description:
-- scenario/demo/_20_99990102/_10_pre_scripts/config/config.yml --
stfw:
  process:
    scripts:
      some_key: value defined at scenario
-- scenario/demo/_20_99990102/_10_pre_scripts/scripts/100_marker --
#!/bin/bash
touch "${STFW_PROJ_DIR}/executed_day2.txt"
exit 0
-- scenario/demo2/metadata.yml --
description:
-- scenario/demo2/_10_99990101/metadata.yml --
description:
-- scenario/demo2/_10_99990101/_10_pre_scripts/metadata.yml --
description:
-- scenario/demo2/_10_99990101/_10_pre_scripts/config/config.yml --
stfw:
  process:
    scripts: {}
-- scenario/demo2/_10_99990101/_10_pre_scripts/scripts/100_ok --
#!/bin/bash
echo "100_ok"
exit 0
-- plugins/run/_common/setup/10_mark --
#!/bin/bash
echo "run setup" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/run/_common/teardown/90_mark --
#!/bin/bash
echo "run teardown ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/scenario/_common/setup/10_mark --
#!/bin/bash
echo "scenario setup ${stfw_scenario_name}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/scenario/_common/teardown/90_mark --
#!/bin/bash
echo "scenario teardown ${stfw_scenario_name} ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/bizdate/_common/setup/10_mark --
#!/bin/bash
echo "bizdate setup ${stfw_bizdate_dirname}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/bizdate/_common/teardown/90_mark --
#!/bin/bash
echo "bizdate teardown ${stfw_bizdate_dirname} ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/process/_common/setup/10_mark --
#!/bin/bash
echo "process setup ${stfw_process_dirname}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/process/_common/teardown/90_mark --
#!/bin/bash
echo "process teardown ${stfw_process_dirname} ${stfw_run_status} ${stfw_process_retcode}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- hooks_golden.log --
run setup
scenario setup demo
bizdate setup _10_99990101
process setup _10_pre_scripts
process teardown _10_pre_scripts Warn 3
process setup _20_post_scripts
process teardown _20_post_scripts Success 0
bizdate teardown _10_99990101 Warn
bizdate setup _20_99990102
process setup _10_pre_scripts
process teardown _10_pre_scripts Success 0
bizdate teardown _20_99990102 Success
scenario teardown demo Warn
run teardown Warn
