# STEP: run 部分実行 --only (指定サブツリーのみ実行する。bizdate 指定と process 指定)

chmod 755 plugins/run/_common/setup/10_mark
chmod 755 plugins/run/_common/teardown/90_mark
chmod 755 plugins/scenario/_common/setup/10_mark
chmod 755 plugins/scenario/_common/teardown/90_mark
chmod 755 plugins/bizdate/_common/setup/10_mark
chmod 755 plugins/bizdate/_common/teardown/90_mark

# bizdate 指定: 該当 bizdate の全 process のみ実行される
exec stfw run demo --only _20_99990102
! exists executed_d1a.txt
! exists executed_d1b.txt
exists executed_d2a.txt
exists executed_d2b.txt

# ジャーナルのイベント列 (ts 以外) がゴールデン一致
# (スキップされた bizdate のイベントが存在しないこと・run attrs に only が入ることも固定する)
normjournal . journal_actual.jsonl
cmp journal_actual.jsonl journal_golden.jsonl

# スキップされた bizdate のフックは実行されない (実行対象の祖先のフックのみ実行される)
cmp hooks.log hooks_golden.log

# process 指定: ピンポイントで 1 process のみ実行される
rm executed_d2a.txt executed_d2b.txt
exec stfw run demo --only _20_99990102/_20_d2b_scripts
! exists executed_d1a.txt
! exists executed_d1b.txt
! exists executed_d2a.txt
exists executed_d2b.txt

normjournal . journal_actual2.jsonl
cmp journal_actual2.jsonl journal_golden2.jsonl

# --dry-run との併用: 対象を計画列挙するが execute はスキップする (AS-BUILT §3.4)
rm executed_d2b.txt
exec stfw run demo --only _20_99990102/_20_d2b_scripts --dry-run
! exists executed_d2b.txt
normjournal . journal_actual3.jsonl
grep '"only":"_20_99990102/_20_d2b_scripts"' journal_actual3.jsonl
grep '"run_mode":"--dry-run"' journal_actual3.jsonl
grep '"steps":\["100_mark"\]' journal_actual3.jsonl

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  timezone: "Asia/Tokyo"
-- scenario/demo/metadata.yml --
description:
-- scenario/demo/_10_99990101/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_d1a_scripts/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_d1a_scripts/config/config.yml --
stfw:
  process:
    scripts:
      some_key: value
-- scenario/demo/_10_99990101/_10_d1a_scripts/scripts/100_mark --
#!/bin/bash
touch "${STFW_PROJ_DIR}/executed_d1a.txt"
exit 0
-- scenario/demo/_10_99990101/_20_d1b_scripts/metadata.yml --
