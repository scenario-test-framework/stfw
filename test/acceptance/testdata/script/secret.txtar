# STEP: encrypt passwd (integration_test.sh の gen-encrypt-key / passwd 相当)

exec stfw init

# キーペア生成: 受信者公開鍵が出力され、config/encrypt/ 配下に保存される
exec stfw secret keygen
stdout '^age1'
exists config/encrypt/key.txt
exists config/encrypt/key.txt.pub

# 再 keygen は --force なしでエラー (v0.2 互換の抑止条件, exit 6)
execcode 6 stfw secret keygen
stderr 'already exists'

# --force で再生成できる
exec stfw secret keygen --force

# set → show のラウンドトリップ
exec stfw secret set 127.0.0.1 some_user password1
exists config/passwd/127.0.0.1-some_user
exec stfw secret show 127.0.0.1 some_user
stdout '^password1$'

# 重複登録は --force なしでエラー (v0.2 互換の禁止条件, exit 6)
execcode 6 stfw secret set 127.0.0.1 some_user password2
stderr 'already exists'

# --force で上書きできる
exec stfw secret set --force 127.0.0.1 some_user password2
exec stfw secret show 127.0.0.1 some_user
stdout '^password2$'
! stdout 'password1'

# password 引数省略時は標準入力から読み込む (非 terminal 経路)
stdin stdin_password.txt
exec stfw secret set 127.0.0.1 other_user
exec stfw secret show 127.0.0.1 other_user
stdout '^piped-secret$'

# 暗号化ファイルは age armor 形式で、平文を含まない
grep 'BEGIN AGE ENCRYPTED FILE' config/passwd/127.0.0.1-other_user
! grep 'piped-secret' config/passwd/127.0.0.1-other_user

# 未登録エントリの show はエラー
! exec stfw secret show 127.0.0.1 unknown_user

-- stdin_password.txt --
piped-secret
