# STEP: collectFile プラグイン (ホストからファイル収集 → エビデンス規約出力)
# ssh / scp / sshpass はモックし、擬似リモート ${WORK}/remote/{host}/ から収集する。

env PATH=${WORK}/fakebin:${PATH}
env STFW_TEST_REMOTE=${WORK}/remote
chmod 755 fakebin/ssh
chmod 755 fakebin/scp
chmod 755 fakebin/sshpass

# 暗号鍵とシークレット (host-user のパスワード) を用意
exec stfw secret keygen
exec stfw secret set web01 appuser secretpw

# 収集実行 (collectFile は組み込み。run が embed から解決・展開する)
exec stfw run demo
latestrun . RUN

# エビデンスディレクトリ規約どおり run ワークスペース内に収集されている (AS-BUILT §5.7)
exists .stfw/runs/$RUN/workspace/demo/_10_99990101/_10_grp_collectFile/evidence/web01/var/log/app/access.log
exec cat .stfw/runs/$RUN/workspace/demo/_10_99990101/_10_grp_collectFile/evidence/web01/var/log/app/access.log
stdout 'hello from remote access.log'

# 空白を含むパスも壊れず収集される (word-splitting 修正の固定)
exists .stfw/runs/$RUN/workspace/demo/_10_99990101/_10_grp_collectFile/evidence/web01/var/log/app/'with space.log'

# パターンに合致しないファイルは収集されない
! exists .stfw/runs/$RUN/workspace/demo/_10_99990101/_10_grp_collectFile/evidence/web01/var/log/app/other.txt

# scenario/ 正本には書き込まれない
! exists scenario/demo/_10_99990101/_10_grp_collectFile/evidence

# ssh 失敗 (接続・認証エラー = 255) は握りつぶさず collect を失敗させる
env STFW_TEST_SSH_FAIL=1
execcode 6 stfw run demo
stderr 'ssh failed'

# inventory list の失敗 (inventory ファイル不在) も握りつぶさず失敗させる
env STFW_TEST_SSH_FAIL=0
cp badstfw.yml stfw.yml
execcode 6 stfw run demo
stderr 'inventory list failed'

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  inventory: staging.yml
-- badstfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  inventory: missing.yml
-- config/inventory/staging.yml --
stfw_inventory:
  - web:
    - web01
-- scenario/demo/metadata.yml --
description:
-- scenario/demo/_10_99990101/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_grp_collectFile/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_grp_collectFile/config/config.yml --
stfw:
  process:
    collectFile:
      targets:
        - group: web
          user: appuser
          paths:
            - /var/log/app/.*\.log
-- remote/web01/manifest --
/var/log/app/access.log
/var/log/app/with space.log
/var/log/app/other.txt
-- remote/web01/var/log/app/access.log --
hello from remote access.log
-- remote/web01/var/log/app/with space.log --
spaced path content
-- remote/web01/var/log/app/other.txt --
should not be collected
-- fakebin/sshpass --
#!/bin/bash
# sshpass -p <pw> <cmd...> -> <cmd...>
if [ "$1" = "-p" ]; then shift 2; fi
exec "$@"
-- fakebin/ssh --
#!/bin/bash
# ssh <opts> user@host "find / ... -regex 'PAT' ..." を擬似リモートの manifest で再現
if [ "${STFW_TEST_SSH_FAIL:-}" = "1" ]; then exit 255; fi
host=""
for a in "$@"; do case "$a" in *@*) host="${a#*@}";; esac; done
cmd="${@: -1}"
pat="$(sed -n "s/.*-regex '\([^']*\)'.*/\1/p" <<<"$cmd")"
manifest="${STFW_TEST_REMOTE}/${host}/manifest"
[ -f "$manifest" ] || exit 0
if [ -n "$pat" ]; then grep -E "$pat" "$manifest"; else cat "$manifest"; fi
exit 0
-- fakebin/scp --
#!/bin/bash
# scp <opts> user@host:/path destdir/ を擬似リモートからのコピーで再現
dest="${@: -1}"
src="${@: -2:1}"
host="${src%%:*}"; host="${host#*@}"
path="${src#*:}"
cp "${STFW_TEST_REMOTE}/${host}${path}" "${dest}"
exit 0
