stfw:
  process:
    clearRedis:
      host_group: kv
      user: appuser
      key_patterns:
        - match: 'demo:*'
-- scenario/redis/_10_99990101/_20_grp_importRedis/metadata.yml --
description:
-- scenario/redis/_10_99990101/_20_grp_importRedis/config/config.yml --
