  process:
    exportRedis:
      host_group: kv
      user: appuser
      key_patterns:
        - name: bad
          match: 'bad:*'
-- fakebin/redis-cli --
#!/bin/bash
# fake redis-cli: シードした keyspace を返し、DEL / import コマンドをログする。
scan=0
pattern='*'
usr=""
cmd=""
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h | -p | -n) shift 2 ;;
    --user) usr="$2"; shift 2 ;;
    --no-auth-warning | -2 | -3 | -e | --json | --raw | --no-raw) shift ;;
    --scan) scan=1; shift ;;
    --pattern) pattern="$2"; shift 2 ;;
    *) cmd="$1"; shift; args=("$@"); break ;;
  esac
done

# マスキング検証用にあえてパスワードを stderr へ出す
echo "redis connect pw=${REDISCLI_AUTH:-}" >&2

if [ "${STFW_TEST_REDIS_FAIL:-0}" = "1" ]; then
  echo "redis: simulated failure" >&2
  exit 1
fi

if [ "$scan" = "1" ]; then
  # 実装側のキーソートを検証するため、あえて降順で返す (未ソートを再現)。
  for f in "${STFW_TEST_REDIS}"/*.type; do
    [ -e "$f" ] || continue
    k="$(basename "$f" .type)"
    # shellcheck disable=SC2254
    case "$k" in
      $pattern) echo "$k" ;;
    esac
  done | sort -r
  exit 0
fi

case "$cmd" in
  TYPE) cat "${STFW_TEST_REDIS}/${args[0]}.type" || exit 1 ;;
  TTL) cat "${STFW_TEST_REDIS}/${args[0]}.ttl" || exit 1 ;; # .ttl 不在時は非 0
  GET | LRANGE | SMEMBERS | HGETALL | ZRANGE) cat "${STFW_TEST_REDIS}/${args[0]}.json" || exit 1 ;;
  DEL) echo "DEL ${args[0]}" >> "${STFW_TEST_REDIS_LOG}" ;;
  "") echo "IMPORT user=${usr}" >> "${STFW_TEST_REDIS_LOG}"; cat >> "${STFW_TEST_REDIS_LOG}" ;;
  *) echo "redis: unsupported cmd $cmd" >&2; exit 1 ;;
esac
exit 0
