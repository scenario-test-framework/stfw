# STEP: Redis export / import / clear プラグイン
# redis-cli をモックし、シードした keyspace (型/TTL/JSON 値) を返す。
# export は各キーの値を stfw plugin redis-encode-row で正規化 + CSV 化する。

env PATH=${WORK}/fakebin:${PATH}
env STFW_TEST_REDIS=${WORK}/redisdata
env STFW_TEST_REDIS_LOG=${WORK}/redis.log
chmod 755 fakebin/redis-cli

# 暗号鍵とシークレット (host-user のパスワード) を用意
exec stfw secret keygen
exec stfw secret set redis01 appuser secretpw

# 実行: clear(_10) → import(_20) → export(_30)
exec stfw run redis

# パスワードがマスクされている
stderr '\[secret\]'
! stderr 'secretpw'

# export: 型ごとに正規化された CSV がエビデンス規約どおり出力される
cmp scenario/redis/_10_99990101/_30_grp_exportRedis/evidence/redis01/demo.csv demo.csv.golden

# clear が SCAN 一致キーを DEL、import が decode コマンドを発行している
exec cat ${WORK}/redis.log
stdout 'DEL demo:h'
stdout 'SET "u:1" "alice"'
stdout 'DEL "u:1"'
# importRedis も ACL --user を渡している
stdout 'IMPORT user=appuser'

# export 失敗 (redis-cli 非 0) は握りつぶさず exit 6
env STFW_TEST_REDIS_FAIL=1
execcode 6 stfw run rexp
stderr 'scan failed'
env STFW_TEST_REDIS_FAIL=0

# import のソース CSV 不在は exit 6
execcode 6 stfw run rimp
stderr 'source csv not found'

# per-key の redis-cli 失敗 (TTL 取得不可) を握りつぶさず exit 6
execcode 6 stfw run rttlerr
stderr 'TTL failed'
# 不完全な CSV は成果物として公開しない
! exists scenario/rttlerr/_10_99990101/_10_grp_exportRedis/evidence/redis01/bad.csv

# inventory list の失敗も握りつぶさず exit 6
cp badstfw.yml stfw.yml
execcode 6 stfw run rexp
stderr 'inventory list failed'

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  inventory: staging.yml
-- badstfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  inventory: missing.yml
-- config/inventory/staging.yml --
stfw_inventory:
  - kv:
    - redis01
-- redisdata/demo:s.type --
string
-- redisdata/demo:s.ttl --
-1
-- redisdata/demo:s.json --
"hello"
-- redisdata/demo:l.type --
list
-- redisdata/demo:l.ttl --
-1
-- redisdata/demo:l.json --
["a","b"]
-- redisdata/demo:h.type --
hash
-- redisdata/demo:h.ttl --
100
-- redisdata/demo:h.json --
["f2","v2","f1","v1"]
-- redisdata/demo:se.type --
set
-- redisdata/demo:se.ttl --
-1
-- redisdata/demo:se.json --
["y","x"]
-- redisdata/demo:z.type --
zset
-- redisdata/demo:z.ttl --
-1
-- redisdata/demo:z.json --
["m2","2","m1","1"]
-- redisdata/bad:1.type --
string
-- redisdata/bad:1.json --
"x"
-- demo.csv.golden --
key,type,ttl,value
demo:h,hash,100,"{""f1"":""v1"",""f2"":""v2""}"
demo:l,list,-1,"[""a"",""b""]"
demo:s,string,-1,hello
demo:se,set,-1,"[""x"",""y""]"
demo:z,zset,-1,"[[""m1"",""1""],[""m2"",""2""]]"
-- scenario/redis/metadata.yml --
description:
-- scenario/redis/_10_99990101/metadata.yml --
description:
-- scenario/redis/_10_99990101/_10_grp_clearRedis/metadata.yml --
description:
