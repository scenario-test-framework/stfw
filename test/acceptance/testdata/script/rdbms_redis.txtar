  process:
    importRedis:
      host_group: kv
      user: appuser
      key_patterns:
        - name: users
-- scenario/redis/_10_99990101/_20_grp_importRedis/data/redis01/users.csv --
key,type,ttl,value
u:1,string,-1,alice
u:2,string,-1,bob
-- scenario/redis/_10_99990101/_30_grp_exportRedis/metadata.yml --
description:
-- scenario/redis/_10_99990101/_30_grp_exportRedis/config/config.yml --
