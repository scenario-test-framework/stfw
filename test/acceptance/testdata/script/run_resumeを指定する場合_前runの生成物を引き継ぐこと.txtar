# STEP: resume (AS-BUILT §5.8)
# --resume は前 run のワークスペース (エビデンス等の生成物) を新しい run へ引き継ぐ。
# 検証内容:
#   - 全体実行 → 後続プロセスが前段のエビデンスを参照して Success
#   - resume なしの --only 部分実行 → クリーンなワークスペースのためエビデンス不在で exit 6
#   - --resume + --only → 前 run のエビデンスを引き継いで Success (stdout に resume_from 行)
#   - --resume=<run_id> の明示指定も動作する
#   - --resume= (空値) と、run が無い状態での --resume はエラー

# run が 1 つも無い状態での --resume はエラー
execcode 6 stfw run --resume demo
stderr 'resume: '

# --resume= (空値) は「最新 run」に化けさせずエラー
execcode 6 stfw run --resume= demo
stderr 'resume'

# --- 全体実行: _10 がエビデンスを生成し、_20 がそれを参照して Success ---
exec stfw run demo
latestrun . RUN1
exists .stfw/runs/$RUN1/workspace/demo/_10_99990101/_10_gen_scripts/evidence/out.txt

# --- --resume + --only: 最新 run (RUN1) のエビデンスを引き継いで Success ---
exec stfw run --resume --only _10_99990101/_20_use_scripts demo
stdout 'resume_from: _'
latestrun . RUN2
exists .stfw/runs/$RUN2/workspace/demo/_10_99990101/_10_gen_scripts/evidence/out.txt
exists .stfw/runs/$RUN2/workspace/demo/_10_99990101/_20_use_scripts/evidence/used.txt
# ジャーナルの run node_start に引き継ぎ元 run_id が記録される (§5.3 resume_from)
grep '"resume_from":"'$RUN1'"' .stfw/runs/$RUN2/journal.jsonl

# --- resume なしの --only: 新しいワークスペースにはエビデンスが無く exit 6 ---
execcode 6 stfw run --only _10_99990101/_20_use_scripts demo
stderr 'evidence not found for use step'

# --- --resume=<run_id> の明示指定: 直前の失敗 run が最新になっていても、
#     エビデンスを持つ RUN1 を指定して Success ---
exec stfw run --resume=$RUN1 --only _10_99990101/_20_use_scripts demo
latestrun . RUN3
exists .stfw/runs/$RUN3/workspace/demo/_10_99990101/_20_use_scripts/evidence/used.txt

# --- 不正な run_id はエラー ---
execcode 6 stfw run --resume=_99999999999999_1 demo
stderr 'resume: run _99999999999999_1 is not exist'

# --- 引き継ぎ元に対象シナリオが無い場合は run を開始せずエラー (phantom run を作らない) ---
execcode 6 stfw run --resume=$RUN1 other
stderr 'resume: scenario other is not in run'
! stdout 'run_id:'

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
-- scenario/demo/metadata.yml --
description:
-- scenario/demo/_10_99990101/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_gen_scripts/metadata.yml --
description:
-- scenario/demo/_10_99990101/_10_gen_scripts/config/config.yml --
stfw:
  process:
    scripts: {}
-- scenario/demo/_10_99990101/_10_gen_scripts/scripts/100_gen --
#!/bin/bash
mkdir -p "${stfw_process_dir}/evidence"
echo "generated by ${run_id}" >"${stfw_process_dir}/evidence/out.txt"
exit 0
-- scenario/demo/_10_99990101/_20_use_scripts/metadata.yml --
description:
-- scenario/demo/_10_99990101/_20_use_scripts/config/config.yml --
stfw:
  process:
    scripts: {}
-- scenario/other/metadata.yml --
description:
-- scenario/other/_10_99990101/metadata.yml --
description:
-- scenario/other/_10_99990101/_10_pre_scripts/metadata.yml --
description:
-- scenario/other/_10_99990101/_10_pre_scripts/config/config.yml --
stfw:
  process:
    scripts: {}
-- scenario/other/_10_99990101/_10_pre_scripts/scripts/100_ok --
#!/bin/bash
exit 0
-- scenario/demo/_10_99990101/_20_use_scripts/scripts/100_use --
#!/bin/bash
src="${stfw_bizdate_dir}/_10_gen_scripts/evidence/out.txt"
if [ ! -f "${src}" ]; then
  echo "evidence not found for use step" >&2
  exit 6
fi
mkdir -p "${stfw_process_dir}/evidence"
cp "${src}" "${stfw_process_dir}/evidence/used.txt"
exit 0
