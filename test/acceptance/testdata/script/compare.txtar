-- fakebin/curl --
#!/bin/bash
# curl -fsSL <url> -o <out> をフィクスチャ tarball のコピーで再現
out=""
while [ $# -gt 0 ]; do
  case "$1" in -o) out="$2"; shift 2;; *) shift;; esac
done
cp "${STFW_TEST_CF_TARBALL}" "${out}"
exit 0
-- fakebin/fakecomparefiles --
#!/bin/bash
# fake compare_files: 左(expect)配下の各ファイルを右(actual)と突合し
# CompareSummary.csv を出力する。0=全一致 / 3=差分 / 6=引数エラー。symlink は追従。
out="result"
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    -od | --outputDir) out="$2"; shift 2 ;;
    -config | --configFile | -layout | --overwriteLayoutDir) shift 2 ;;
    -*) shift ;;
    *) args+=("$1"); shift ;;
  esac
done
left="${args[0]:-}"
right="${args[1]:-}"
if [ -z "${left}" ] || [ -z "${right}" ]; then
  echo "fake compare_files: need LEFT RIGHT" >&2
  exit 6
fi
# compare-files 自体のエラー (exit 6) を再現する
if [ "${STFW_TEST_CF_FAIL:-0}" = "1" ]; then
  echo "fake compare_files: simulated error" >&2
  exit 6
fi
mkdir -p "${out}"
summary="${out}/CompareSummary.csv"
echo "Status,Left,Right" > "${summary}"
rc=0
# 左(expect)基準で OK/NG/LeftOnly を判定 (actual 側の symlink は追従して読む)
while IFS= read -r f; do
  rel="${f#"${left}/"}"
  r="${right}/${rel}"
  if [ ! -e "${r}" ]; then
    echo "LeftOnly,${f},${r}" >> "${summary}"; rc=3
  elif ! diff -q "${f}" "${r}" > /dev/null 2>&1; then
    echo "NG,${f},${r}" >> "${summary}"; rc=3
  else
    echo "OK,${f},${r}" >> "${summary}"
  fi
done < <(find "${left}" -type f)
# 右(actual)側の余剰ファイル (RightOnly) も検出する (-L で symlink を追従)
while IFS= read -r f; do
  rel="${f#"${right}/"}"
  l="${left}/${rel}"
  if [ ! -e "${l}" ]; then
    echo "RightOnly,${l},${f}" >> "${summary}"; rc=3
  fi
done < <(find -L "${right}" -type f)
exit ${rc}
