# STEP: compare プラグイン (期待値 expect と収集エビデンス actual を compare-files で突合)
# curl(DL) はモックし、フェイク compare_files で比較を再現する。
# 収集系プロセスの代役として scripts プロセスが evidence を生成する。
#
# 検証内容:
#   - install が実行ホストの os_arch 版 compare_files をキャッシュする
#   - compare が actual/ を evidence への file-level symlink で組み立てる
#   - 一致 → Success、差分 (exit 3) → exit 6、evidence 不在 → exit 6

env PATH=${WORK}/fakebin:${PATH}
chmod 755 fakebin/curl
chmod 755 fakebin/fakecomparefiles

# compare-files リリース tarball のフィクスチャを作る (root 直下に compare_files バイナリ)
mkdir cfsrc
cp fakebin/fakecomparefiles cfsrc/compare_files
chmod 755 cfsrc/compare_files
exec tar czf cf.tar.gz -C cfsrc compare_files
env STFW_TEST_CF_TARBALL=${WORK}/cf.tar.gz

# プロビジョニング (curl はモック)。実行ホストの os_arch 版がキャッシュされ is_installed=true
exec stfw plugin install compare

# --- 一致ケース: evidence と expect が一致 → compare Success ---
exec stfw run cmp
stdout 'run_id: _'

# actual/ が evidence への file-level symlink (コピーではない) として組み立てられている
exists scenario/cmp/_10_99990101/_20_asrt_compare/actual/_10_col_scripts/host1/data.txt
exec readlink scenario/cmp/_10_99990101/_20_asrt_compare/actual/_10_col_scripts/host1/data.txt
stdout '_10_col_scripts/evidence/host1/data.txt'
# symlink 先 (evidence 実体) の内容が読める
exec cat scenario/cmp/_10_99990101/_20_asrt_compare/actual/_10_col_scripts/host1/data.txt
stdout 'hello'
# 比較結果が result/ へ出力される
exists scenario/cmp/_10_99990101/_20_asrt_compare/result/CompareSummary.csv
exec cat scenario/cmp/_10_99990101/_20_asrt_compare/result/CompareSummary.csv
stdout 'OK,'

# --- compare-files 自体のエラー (exit 6) を握りつぶさず exit 6 (差分とは別メッセージ) ---
env STFW_TEST_CF_FAIL=1
execcode 6 stfw run cmp
stderr 'compare-files failed'
env STFW_TEST_CF_FAIL=0

# --- 差分ケース: expect が evidence と異なる → compare-files exit 3 → プラグイン exit 6 ---
execcode 6 stfw run cmpng
stderr 'mismatch detected'

# --- エラーケース: expect が参照する収集 process の evidence が無い → exit 6 ---
execcode 6 stfw run cmperr
stderr 'evidence not found'

# --- 空 evidence: evidence にファイルが無くても actual/{name} は作られ、
#     expect のファイルは LeftOnly として mismatch になる ---
execcode 6 stfw run cmpempty
stderr 'mismatch detected'
exists scenario/cmpempty/_10_99990101/_20_asrt_compare/actual/_10_col_scripts

# --- RightOnly: expect に無い余剰 evidence ファイルも actual へ symlink され、
#     余剰は RightOnly として mismatch になる (プラグインが全 evidence を symlink する完全性) ---
execcode 6 stfw run cmpro
stderr 'mismatch detected'
exists scenario/cmpro/_10_99990101/_20_asrt_compare/actual/_10_col_scripts/host1/extra.txt
exec cat scenario/cmpro/_10_99990101/_20_asrt_compare/result/CompareSummary.csv
stdout 'RightOnly,'

