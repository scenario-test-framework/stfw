-- scenario/demo/_20_99990102/_20_d2b_scripts/scripts/100_mark --
#!/bin/bash
touch "${STFW_PROJ_DIR}/executed_d2b.txt"
exit 0
-- plugins/run/_common/setup/10_mark --
#!/bin/bash
echo "run setup" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/run/_common/teardown/90_mark --
#!/bin/bash
echo "run teardown ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/scenario/_common/setup/10_mark --
#!/bin/bash
echo "scenario setup ${stfw_scenario_name}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/scenario/_common/teardown/90_mark --
#!/bin/bash
echo "scenario teardown ${stfw_scenario_name} ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/bizdate/_common/setup/10_mark --
#!/bin/bash
echo "bizdate setup ${stfw_bizdate_dirname}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
-- plugins/bizdate/_common/teardown/90_mark --
#!/bin/bash
echo "bizdate teardown ${stfw_bizdate_dirname} ${stfw_run_status}" >>"${STFW_PROJ_DIR}/hooks.log"
exit 0
