# STEP: invoke プラグイン (invokeRest / invokeWeb を grafana k6 で実行する Act)
# curl(DL) はモックし、フェイク k6 で実行を再現する。
# k6 のリリース資産は OS で形式が異なる (linux=tar.gz / macos=zip) ため、
# 実行 OS に合わせてフィクスチャを作り分ける。
#
# 検証内容:
#   - install が実行ホストの os_arch 版 k6 をキャッシュする
#   - host が __ENV.stfw_target_host へ、パスワードが環境変数で注入されマスクされる
#   - k6 exit 0 → Success / k6 exit 99 (閾値失敗) → exit 6 / スクリプト不在 → exit 6
#   - invokeWeb はブラウザを既定ヘッドレスにする

env PATH=${WORK}/fakebin:${PATH}
chmod 755 fakebin/curl
chmod 755 fakebin/fakek6

# k6 リリース資産のフィクスチャ (k6src/k6 に fake バイナリ)。OS で形式を作り分ける。
mkdir k6src
cp fakebin/fakek6 k6src/k6
chmod 755 k6src/k6
[linux] exec tar czf k6.tar.gz -C . k6src
[linux] env STFW_TEST_K6_ARCHIVE=${WORK}/k6.tar.gz
[darwin] exec zip -q -r k6.zip k6src
[darwin] env STFW_TEST_K6_ARCHIVE=${WORK}/k6.zip

# プロビジョニング (curl はモック)。invokeRest / invokeWeb それぞれ k6 をキャッシュ
exec stfw plugin install invokeRest
exec stfw plugin install invokeWeb

# 資格情報 (host-user のパスワード)
exec stfw secret keygen
exec stfw secret set api01 appuser secretpw

# --- 正常系 (invokeRest): k6 exit 0 → Success ---
exec stfw run inv
stdout 'run_id: _'
# host が -e で __ENV へ注入される
stdout 'stfw_target_host=api01'
# end-of-test サマリと web dashboard の HTML レポートがエビデンスへ出力される
exists scenario/inv/_10_99990101/_10_act_invokeRest/evidence/summary.json
exists scenario/inv/_10_99990101/_10_act_invokeRest/evidence/report.html
# パスワードは環境変数で渡され、マスクされる (argv には載らない)
stderr '\[secret\]'
! stderr 'secretpw'

# --- 閾値失敗 (k6 exit 99) を握りつぶさず exit 6 ---
env STFW_TEST_K6_EXIT=99
execcode 6 stfw run inv
stderr 'k6 run failed \(exit 99\)'
env STFW_TEST_K6_EXIT=0

# --- スクリプト不在 → exit 6 ---
execcode 6 stfw run invnoscript
stderr 'k6 script not found'

# --- user のみ指定 (host_group 無し) は無言で無認証にせず exit 6 ---
execcode 6 stfw run invnohost
stderr 'user requires host_group'

# --- invokeWeb: ブラウザは既定ヘッドレス ---
exec stfw run invweb
stdout 'K6_BROWSER_HEADLESS=true'
exists scenario/invweb/_10_99990101/_10_act_invokeWeb/evidence/summary.json
exists scenario/invweb/_10_99990101/_10_act_invokeWeb/evidence/report.html

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
  inventory: staging.yml
-- config/inventory/staging.yml --
stfw_inventory:
  - api:
    - api01
-- scenario/inv/metadata.yml --
description:
-- scenario/inv/_10_99990101/metadata.yml --
description:
-- scenario/inv/_10_99990101/_10_act_invokeRest/metadata.yml --
description:
-- scenario/inv/_10_99990101/_10_act_invokeRest/config/config.yml --
stfw:
  process:
    invokeRest:
      host_group: api
      user: appuser
      script: script.js
-- scenario/inv/_10_99990101/_10_act_invokeRest/script.js --
// fake k6 は内容を解釈しない (存在確認用)
export default function () {}
