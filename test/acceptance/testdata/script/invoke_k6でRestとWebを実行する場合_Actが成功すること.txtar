  process:
    invokeWeb:
      script: script.js
-- scenario/invweb/_10_99990101/_10_act_invokeWeb/script.js --
// fake k6 browser script (存在確認用)
export const options = { scenarios: {} }
-- fakebin/curl --
#!/bin/bash
# curl -fsSL <url> -o <out> をフィクスチャ archive のコピーで再現する。
# install の資産名計算 (k6-{version}-{os}-{arch}.{ext}) を検証するため、
# 期待資産名を uname から組み立てて URL と照合する。不一致なら失敗させる。
url=""
out=""
while [ $# -gt 0 ]; do
  case "$1" in
    -o) out="$2"; shift 2 ;;
    -*) shift ;;
    *) url="$1"; shift ;;
  esac
done
case "$(uname -s)" in
  Linux) eos=linux; eext=tar.gz ;;
  Darwin) eos=macos; eext=zip ;;
  *) echo "fake curl: unsupported OS" >&2; exit 1 ;;
esac
case "$(uname -m)" in
  x86_64 | amd64) earch=amd64 ;;
  aarch64 | arm64) earch=arm64 ;;
  *) echo "fake curl: unsupported arch" >&2; exit 1 ;;
esac
expected="k6-v2.1.0-${eos}-${earch}.${eext}"
case "${url}" in
  *"${expected}") ;;
  *) echo "fake curl: unexpected asset url: ${url} (want *${expected})" >&2; exit 22 ;;
esac
cp "${STFW_TEST_K6_ARCHIVE}" "${out}"
exit 0
-- fakebin/fakek6 --
#!/bin/bash
# fake k6: run [flags] script。--summary-export にダミー JSON を書き、
# STFW_TEST_K6_EXIT で終了コードを模擬する。-e KEY=VALUE を収集して echo する。
summary=""
eflags=()
while [ $# -gt 0 ]; do
  case "$1" in
    run) shift ;;
    --summary-export) summary="$2"; shift 2 ;;
    -e) eflags+=("$2"); shift 2 ;;
    *) shift ;;
  esac
done
echo "fake k6: env_flags=${eflags[*]}"
echo "fake k6: K6_BROWSER_HEADLESS=${K6_BROWSER_HEADLESS:-unset}"
# パスワードは環境変数で渡される (argv には載らない) → マスキング検証用に stderr へ
echo "fake k6: target_pw=${stfw_target_password:-none}" >&2
if [ -n "${summary}" ]; then
  mkdir -p "$(dirname "${summary}")"
  echo '{"metrics":{}}' > "${summary}"
fi
exit "${STFW_TEST_K6_EXIT:-0}"
