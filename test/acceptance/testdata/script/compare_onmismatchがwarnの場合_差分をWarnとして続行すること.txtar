# STEP: compare on_mismatch=warn (差分を exit 3 のまま返し、Warn として記録して続行する。
# SPEC-014-02 改訂)
# curl(DL) はモックし、フェイク compare_files で比較を再現する。
#
# 検証内容:
#   - on_mismatch: warn で差分 -> compare プロセスが Warn、後続 process は実行される
#   - run の終了コードは 3 (Warn あり・Error なし)
#   - on_mismatch の不正値は設定不正として exit 6 (fail-fast)
#   - 一致は on_mismatch: warn でも Success

env PATH=${WORK}/fakebin:${PATH}
chmod 755 fakebin/curl
chmod 755 fakebin/fakecomparefiles

# compare-files リリース tarball のフィクスチャを作る (root 直下に compare_files バイナリ)
mkdir cfsrc
cp fakebin/fakecomparefiles cfsrc/compare_files
chmod 755 cfsrc/compare_files
exec tar czf cf.tar.gz -C cfsrc compare_files
env STFW_TEST_CF_TARBALL=${WORK}/cf.tar.gz

# プロビジョニング (curl はモック)
exec stfw plugin install compare

# --- warn + 差分: compare は Warn、後続 process は実行、run は exit 3 ---
execcode 3 stfw run cmpwarn
stderr 'mismatch detected'
stderr 'finished with status Warn'
exists executed_after_compare.txt

# status: compare プロセスが Warn、後続 process は Success、run は Warn 集約
exec stfw status
stdout 'run \[Warn\]'
stdout '\n      _20_asrt_compare \[Warn\]'
stdout '\n      _30_post_scripts \[Success\]'

# --- warn + 一致: on_mismatch: warn でも一致は Success (exit 0) ---
exec stfw run cmpok
stdout 'run_id: _'

# --- 不正値: error / warn 以外は設定不正として fail-fast (exit 6) ---
execcode 6 stfw run cmpbad
stderr 'invalid on_mismatch'

-- stfw.yml --
stfw:
  project_version: 0.1.0
  loglevel: "info"
